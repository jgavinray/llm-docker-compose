# hyper03 production hybrid defaults.

CUDA_VISIBLE_DEVICES=0
MODELS_ROOT=/storage03/models

QWEN36_PORT=8001
QWEN36_MODEL_PATH=/models/Qwen3.6-27B-int4-AutoRound
QWEN36_MODEL_NAME=qwen3.6-27b
QWEN36_MAX_MODEL_LEN=131072
QWEN36_GPU_MEM_UTIL=0.523
QWEN36_MAX_NUM_SEQS=3
QWEN36_NUM_SPEC_TOKENS=5
VLLM_CACHE_DIR=/storage03/vllm-docker-compose/hyper03/vllm-cache

GEMMA4_PORT=8000
GEMMA4_GGUF_MODEL_PATH=/models/gemma4-31b/gguf/gemma-4-31B-it-Q4_K_M.gguf
GEMMA4_MODEL_ALIAS=gemma-4-31b-q4-llamacpp
GEMMA4_CTX_SIZE=393216
GEMMA4_PARALLEL=3
GEMMA4_CACHE_TYPE_K=q8_0
GEMMA4_CACHE_TYPE_V=q8_0
LLAMA_CPP_IMAGE=ghcr.io/ggml-org/llama.cpp:server-cuda13-b9445
